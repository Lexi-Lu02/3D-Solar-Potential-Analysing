# Copy this file to .env and fill in real values. .env must NEVER be committed.

# --- PostgreSQL connection ---
DB_HOST=16.176.25.174
DB_PORT=5432
DB_NAME=melbourne_solar
# In production, use the read-only role: solarmap_api_ro
DB_USER=solarmap_api_ro
DB_PASSWORD=replace-me

# --- Connection pool ---
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# --- CORS ---
# Comma-separated list of allowed origins. Only used during local development.
# In production, frontend and API are served from the same nginx (same-origin),
# so this can be left empty.
CORS_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO
