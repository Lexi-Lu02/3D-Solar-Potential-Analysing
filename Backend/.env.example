# Copy this file to .env and fill in real values. .env must NEVER be committed.

# --- PostgreSQL connection ---
DB_HOST=16.176.25.174
DB_PORT=5432
DB_NAME=melbourne_solar
# In production, use the read-only role: solarmap_api_ro
DB_USER=solarmap_api_ro
DB_PASSWORD=replace-me

# --- Connection pool ---
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# --- CORS ---
# Comma-separated list of allowed origins. Only used during local development.
# In production, frontend and API are served from the same nginx (same-origin),
# so this can be left empty.
CORS_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO

# --- LLM (Qwen via Aliyun DashScope, OpenAI-compatible endpoint) ---
# Get an API key from https://dashscope.console.aliyun.com  -> API-KEY 管理
# Never commit a real key.
DASHSCOPE_API_KEY=replace-me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-flash

# Token / iteration budgets per request
AI_MAX_TOKENS_PER_REQUEST=4000
AI_MAX_TOOL_ITERATIONS=6

# Per-IP rate limit (requests per minute) on /api/v1/ai/*
AI_RATE_LIMIT_PER_MINUTE=10

# History truncation: keep at most N messages and ~M tokens
AI_HISTORY_WINDOW=20
AI_HISTORY_MAX_TOKENS=4000

# Run a second qwen-flash pass to verify the final answer (slower, safer).
# Set to false to save tokens during dev.
AI_ENABLE_SELF_CRITIQUE=true
